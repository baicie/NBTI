{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "types": ["vitest/globals", "node"],
    "paths": {
      "@/*": ["apps/web/*"],
      "@nbti/*": ["packages/*/src"]
    }
  },
  "include": [
    "packages/*/src",
    "packages/*/__tests__",
    "packages/*/__test__",
    "scripts/**/*"
  ],
  "exclude": [
    "**/dist",
    "**/temp",
    "**/node_modules",
    "**/tsconfig.tsbuildinfo"
  ]
}
