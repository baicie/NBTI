  "types": [
    {
      "id": "FISH",
      "name": {
        "zh": "摸鱼圣体"
      },
      "subtitle": {
        "zh": "人坐工位，魂游四海"
      },
      "description": {
        "zh": "你不是单纯偷懒，你是很懂得给精神留逃生通道。面对压力、流程、表格、会议，你总能在身体在线的情况下，让灵魂先出去透口气。你对“假装在忙”这件事，已经形成了近乎艺术的理解。"
      },
      "icon": "fish",
      "color": "#5BAA6F",
      "posterImage": {
        "zh": "/types/abstract-personality-draw/fish.png"
      },
      "rarity": "normal",
      "traits": [
        {
          "id": "spiritual-roaming",
          "name": {
            "zh": "灵魂远游"
          },
          "icon": "waves",
          "level": 94,
          "description": {
            "zh": "人还在现场，心已经跑到精神海岛。"
          }
        },
        {
          "id": "office-camouflage",
          "name": {
            "zh": "职场伪装"
          },
          "icon": "monitor",
          "level": 88,
          "description": {
            "zh": "鼠标在动，窗口很多，实际核心业务是放空。"
          }
        },
        {
          "id": "energy-saving",
          "name": {
            "zh": "精神节能"
          },
          "icon": "battery-low",
          "level": 91,
          "description": {
            "zh": "能少消耗一点，就绝不多燃烧一分。"
          }
        }
      ],
      "strengths": [
        {
          "zh": "擅长在高压环境中保持精神弹性"
        },
        {
          "zh": "能把无聊日常变成灵魂出逃路线"
        },
        {
          "zh": "看似松弛，实际很会保存体力"
        }
      ],
      "weaknesses": [
        {
          "zh": "容易把“马上开始”拖成“精神准备中”"
        },
        {
          "zh": "看起来一直在线，其实经常内部断联"
        }
      ],
      "compatibleTypes": ["CHILL", "OFFL", "MELON"],
      "incompatibleTypes": ["PLAN", "TALK"],
      "relationships": {
        "zh": "你在关系里通常不制造压力，主打一个轻轻陪伴、慢慢漂流。别人催你，你会点头；别人不催你，你会继续漂。"
      },
      "workStyle": {
        "zh": "适合有弹性、有空间、有喘息感的工作节奏。最怕无尽会议、即时响应和“你现在马上”。"
      },
      "communicationStyle": {
        "zh": "常用话术包括“我在看了”“马上弄”“快好了”。其中“快好了”的时间单位非常玄学。"
      },
      "quotes": [
        {
          "text": "你不是在偷懒，你是在给灵魂放风。",
          "author": "摸鱼圣体"
        }
      ]
    },
    {
      "id": "UNDO",
      "name": {
        "zh": "撤回大师"
      },
      "subtitle": {
        "zh": "先发制人，再删为敬"
      },
      "description": {
        "zh": "你是冲动表达和极速后悔的结合体。你的手往往比脑子快一步，消息先出去，灵魂后追上。但你并不慌，因为你相信：只要撤回够快，命运就追不上你。"
      },
      "icon": "undo-2",
      "color": "#4F8F7B",
      "posterImage": {
        "zh": "/types/abstract-personality-draw/undo.png"
      },
      "rarity": "normal",
      "traits": [
        {
          "id": "instant-regret",
          "name": {
            "zh": "秒级后悔"
          },
          "icon": "timer-reset",
          "level": 96,
          "description": {
            "zh": "发送三秒后，人生进入复盘模式。"
          }
        },
        {
          "id": "message-surgeon",
          "name": {
            "zh": "聊天外科手术"
          },
          "icon": "scissors",
          "level": 89,
          "description": {
            "zh": "精准切除刚才那句不该说的话。"
          }
        },
        {
          "id": "dignity-repair",
          "name": {
            "zh": "体面修补"
          },
          "icon": "bandage",
          "level": 83,
          "description": {
            "zh": "撤回以后还能假装什么都没发生。"
          }
        }
      ],
      "strengths": [
        {
          "zh": "反应快，纠错快，求生欲强"
        },
        {
          "zh": "很懂语言风险控制"
        },
        {
          "zh": "能在尴尬发生前尝试拯救现场"
        }
      ],
      "weaknesses": [
        {
          "zh": "有时撤回比解释更让人好奇"
        },
        {
          "zh": "容易在聊天框里上演心理惊悚片"
        }
      ],
      "compatibleTypes": ["GHOST", "HARD", "MAYBE"],
      "incompatibleTypes": ["TALK", "VIBE"],
      "relationships": {
        "zh": "你在关系里很怕说错话，但又忍不住想表达。你不是冷淡，你只是每句话都可能经历生死审判。"
      },
      "workStyle": {
        "zh": "适合有修改空间的工作，不适合发出去就无法撤回的场面。"
      },
      "communicationStyle": {
        "zh": "发送、撤回、沉默、补一句、再撤回。你的聊天记录像一场小型魔术表演。"
      },
      "quotes": [
        {
          "text": "话可以先说，体面稍后补救。",
          "author": "撤回大师"
        }
      ]
    },
    {
      "id": "LATE",
      "name": {
        "zh": "拖延战神"
      },
      "subtitle": {
        "zh": "不逼到最后，绝不启动天赋"
      },
      "description": {
        "zh": "你不是不会做，你只是必须等时间把你逼到墙角，才能激活真正的自己。越是死线逼近，你越容易进入一种诡异的高效状态。平时像待机，最后一刻像开了外挂。"
      },
      "icon": "alarm-clock",
      "color": "#B88746",
      "posterImage": {
        "zh": "/types/abstract-personality-draw/late.png"
      },
      "rarity": "normal",
      "traits": [
        {
          "id": "deadline-awakening",
          "name": {
            "zh": "死线觉醒"
          },
          "icon": "zap",
          "level": 97,
          "description": {
            "zh": "不到最后一刻，天赋绝不轻易上线。"
          }
        },
        {
          "id": "false-calm",
          "name": {
            "zh": "虚假淡定"
          },
          "icon": "smile",
          "level": 87,
          "description": {
            "zh": "嘴上来得及，心里也许真的来得及。"
          }
        },
        {
          "id": "last-minute-burst",
          "name": {
            "zh": "临门爆发"
          },
          "icon": "rocket",
          "level": 92,
          "description": {
            "zh": "越接近崩盘，越像突然装了涡轮。"
          }
        }
      ],
      "strengths": [
        {
          "zh": "抗压时有奇怪爆发力"
        },
        {
          "zh": "能在极限时间里完成不可思议的事"
        },
        {
          "zh": "心理素质看似离谱但经常有效"
        }
      ],
      "weaknesses": [
        {
          "zh": "容易把人生过成倒计时挑战"
        },
        {
          "zh": "长期让自己处于惊险刺激边缘"
        }
      ],
      "compatibleTypes": ["NITE", "CRAZY", "FISH"],
      "incompatibleTypes": ["PLAN"],
      "relationships": {
        "zh": "你常让身边人替你着急，但你自己总觉得还能再等等。"
      },
      "workStyle": {
        "zh": "没有截止日期就没有启动按钮，有了截止日期就像被雷劈醒。"
      },
      "communicationStyle": {
        "zh": "你最常说“来得及”，而且最可怕的是，有时真的来得及。"
      },
      "quotes": [
        {
          "text": "我的天赋不是效率，是在崩盘边缘精准点火。",
          "author": "拖延战神"
        }
      ]
