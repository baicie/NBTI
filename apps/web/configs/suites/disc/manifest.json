{
  "id": "disc",
  "name": { "zh": "DISC 性格测试", "en": "DISC Personality" },
  "version": "1.0.0",
  "description": {
    "zh": "DISC 是一种行为风格评估工具，帮助你了解自己在不同情境下的行为倾向",
    "en": "DISC is a behavior style assessment tool"
  },
  "thumbnail": "/thumbnails/disc.png",
  "dimensions": ["D", "I", "S", "C"],
  "config": {
    "questions": "questions.json",
    "types": "types.json",
    "themes": "theme.json"
  },
