    "layout": "single",
    "allowBack": true,
    "showTimer": false,
    "shuffleQuestions": false,
    "shuffleOptions": false,
    "requiredAnswer": true,
    "maxDuration": null,
    "showDimensions": true
  },
  "background": {
    "enabled": false,
    "image": "",
    "opacity": 0.5,
    "position": "center",
    "size": "cover"
  },
  "scoring": {
    "type": "dimension",
    "dimensions": ["D", "I", "S", "C"],
    "calculateMethod": "percentage",
    "normalizeOutput": true
  }
}
