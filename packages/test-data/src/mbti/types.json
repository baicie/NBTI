        "en": "Intuition — Sensing"
      },
      "left": {
        "letter": "N",
        "name": {
          "zh": "直觉",
          "en": "Intuition"
        },
        "description": {
          "zh": "你通过想象力和第六感获取信息，关注可能性",
          "en": "You prefer to use imagination and intuition, focusing on possibilities"
        }
      },
      "right": {
        "letter": "S",
        "name": {
          "zh": "实感",
          "en": "Sensing"
        },
        "description": {
          "zh": "你通过五官和实际经验获取信息，关注现实",
          "en": "You prefer to use your senses and practical experience, focusing on what is real"
        }
      }
    },
    {
