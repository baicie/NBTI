{
  "name": "root",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @nbti/web dev",
    "dev:all": "pnpm --filter @nbti/web dev",
    "build": "pnpm --filter @nbti/web build",
    "clean": "rimraf --glob packages/*/dist temp .eslintcache",
    "check": "tsc --incremental --noEmit",
    "lint": "eslint --cache .",
    "format": "prettier --write --cache .",
    "format-check": "prettier --check --cache .",
    "test": "vitest",
    "test-unit": "vitest --project unit*",
    "test-e2e": "vitest --project e2e --passWithNoTests",
    "test-coverage": "vitest run --project unit* --coverage",
    "install:all": "pnpm install",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged && pnpm check",
    "commit-msg": "node -e \"import('@baicie/scripts').then(m => m.verifyCommit())\""
  },
  "lint-staged": {
    "*.{js,json}": [
      "prettier --write"
    ],
    "*.ts?(x)": [
      "eslint --fix",
      "prettier --parser=typescript --write"
    ]
  },
  "engines": {
    "node": ">=18.12.0"
  },
  "devDependencies": {
    "@baicie/scripts": "^0.1.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/eslint-plugin": "^1.6.15",
    "eslint": "^10.2.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "picocolors": "^1.1.1",
    "prettier": "^3.8.2",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4",
    "zod": "^4.3.6"
  }
}
