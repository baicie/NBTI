{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "tsBuildInfoFile": "../node_modules/.cache/tsbuildinfo/build.tsbuildinfo",
    "types": ["node"],
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "stripInternal": true
  },
  "include": ["../packages/*/src"],
  "exclude": [
    "**/__tests__",
    "**/dist",
    "**/playground",
    "**/node_modules",
    "packages/napi"
  ]
}
